<?xml version="1.0"?>
<robot name="mirmi_robot">

  <!-- ═══════════════════════════════════════════════════════════
       MIRMI Robot Description
       Defines the static sensor frames relative to base_link.
       Published by robot_state_publisher via rsp.launch.py.
       ═══════════════════════════════════════════════════════════ -->
  <!-- ── Robot body ─────────────────────────────────────────── -->
  <link name="base_link"/>

  <!-- ── Camera (RealSense / USB)  ──────────────────────────── -->
  <!--
      Mounting: front of robot, slightly forward and upward.
      The optical frame uses the ROS camera convention:
        x-right, y-down, z-forward
      We apply a 90° rotation around X and then 90° around Z
      to convert from robot (x-forward, y-left, z-up) to
      optical (x-right, y-down, z-forward).
  -->
  <link name="camera_link"/>
  <joint name="base_link_to_camera_link" type="fixed">
    <parent link="base_link"/>
    <child  link="camera_link"/>
    <!-- 18.75 cm forward, centred laterally, 18.75 cm below sphere origin -->
    <origin xyz="0.1875 0.0 -0.1875" rpy="0.0 0.0 0.0"/>
  </joint>

  <!-- Optical frame: z-forward, x-right, y-down -->
  <link name="camera_color_optical_frame"/>
  <joint name="camera_link_to_optical" type="fixed">
    <parent link="camera_link"/>
    <child  link="camera_color_optical_frame"/>
    <origin xyz="0.0 0.0 0.0" rpy="1.5707963267948966 0.0 1.5707963267948966"/>
  </joint>

  <!-- ── LIDAR ────────────────────────────────────────────────── -->
  <!--
      Mounting: top-centre of the robot, facing upward/forward.
      Adjust xyz/rpy to match physical placement.
  -->
  <!--
  <link name="lidar_link"/>
  <joint name="base_link_to_lidar" type="fixed">
    <parent link="base_link"/>
    <child  link="lidar_link"/>
    <origin xyz="0.05 0.0 0.15" rpy="0.0 0.0 0.0"/>
  </joint>
  -->

  <!-- ── GPS ──────────────────────────────────────────────────── -->
  <!--
      Mounting: top of the robot body.
      Adjust xyz to match the physical GPS antenna position.
  -->
  <!--
  <link name="gps_link"/>
  <joint name="base_link_to_gps" type="fixed">
    <parent link="base_link"/>
    <child  link="gps_link"/>
    <origin xyz="0.0 0.0 0.20" rpy="0.0 0.0 0.0"/>
  </joint>
  -->

  <!-- ── IMU ──────────────────────────────────────────────────── -->
  <!--
      Mounting: body-centred (typically coincides with base_link).
      Adjust if the IMU is physically offset.
  -->
  <!--
  <link name="imu_link"/>
  <joint name="base_link_to_imu" type="fixed">
    <parent link="base_link"/>
    <child  link="imu_link"/>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
  </joint>
  -->

</robot>
